    </node>
    <node id="Reward Models">
      <data key="d0">Reward Models</data>
      <data key="d1">method</data>
      <data key="d2">Reward models are trained to discriminate among multiple candidate explanations and learn their relative quality.</data>
      <data key="d3">chunk-a42210fb81e37b65a494b714686acf98</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777541247</data>

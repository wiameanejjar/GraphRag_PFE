    <node id="Ordinal Structure">
      <data key="d0">Ordinal Structure</data>
      <data key="d1">concept</data>
      <data key="d2">Ordinal structure is preserved by listwise ranking models to evaluate the relative quality of explanations.</data>
      <data key="d3">chunk-a42210fb81e37b65a494b714686acf98</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777541273</data>

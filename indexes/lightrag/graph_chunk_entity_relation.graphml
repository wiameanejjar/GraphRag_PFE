    <node id="Deep Learning-Enabled Dissolved Oxygen Sensing">
      <data key="d0">Deep Learning-Enabled Dissolved Oxygen Sensing</data>
      <data key="d1">concept</data>
      <data key="d2">Deep Learning-Enabled Dissolved Oxygen Sensing is a sensing paradigm that combines camera-based DO sensors with a visual transformer (ViT)-based physics-informed neural network (PINN) for high-fidelity sensing under biofouling conditions.</data>
      <data key="d3">chunk-e755a3b7fb7a07c10fdd800c398a82c8</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777540343</data>
      <data key="d6" />
    </node>
    <node id="Climate Crisis">
      <data key="d0">Climate Crisis</data>
      <data key="d1">concept</data>
      <data key="d2">The Climate Crisis is an escalating global issue that demands intelligent, low-cost sensors capable of robust, long-term monitoring in real-world environments.</data>
      <data key="d3">chunk-e755a3b7fb7a07c10fdd800c398a82c8</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777540343</data>
      <data key="d6" />
    </node>
    <node id="Ocean Monitoring">
      <data key="d0">Ocean Monitoring</data>
      <data key="d1">concept</data>
      <data key="d2">Ocean Monitoring is the process of tracking and analyzing ocean conditions, including dissolved oxygen concentration, to predict climate tipping points.</data>
      <data key="d3">chunk-e755a3b7fb7a07c10fdd800c398a82c8</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777540346</data>
      <data key="d6" />
    </node>

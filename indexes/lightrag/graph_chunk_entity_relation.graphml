    <node id="The Price of Agreement">
      <data key="d0">The Price of Agreement</data>
      <data key="d1">content</data>
      <data key="d2">The Price of Agreement is a title that discusses the safety and robustness of LLMs in financial systems.</data>
      <data key="d3">chunk-cd622ac8154940cde02b38a335a93d0b</data>
      <data key="d4">unknown_source</data>

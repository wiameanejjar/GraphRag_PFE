    </node>
    <node id="Score Separation">
      <data key="d0">Score Separation</data>
      <data key="d1">concept</data>
      <data key="d2">Score separation refers to the ability to distinguish between different quality levels of explanations.</data>
      <data key="d3">chunk-a42210fb81e37b65a494b714686acf98</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777541258</data>
      <data key="d6" />
    </node>
    <node id="Data Characteristics">
      <data key="d0">Data Characteristics</data>
      <data key="d1">concept</data>
      <data key="d2">Data characteristics, such as quality tiers, affect the optimal ranking loss.</data>
      <data key="d3">chunk-a42210fb81e37b65a494b714686acf98</data>

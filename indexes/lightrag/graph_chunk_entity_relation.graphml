      <data key="d0">Absolute Dissolved Oxygen Concentration</data>
      <data key="d1">concept</data>
      <data key="d2">Absolute Dissolved Oxygen Concentration is a key parameter for predicting climate tipping points and is a focus of the Deep Learning-Enabled Dissolved Oxygen Sensing paradigm.</data>
      <data key="d3">chunk-e755a3b7fb7a07c10fdd800c398a82c8</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777540350</data>
      <data key="d6" />
    </node>
    <node id="Optoelectronic Sensors">
      <data key="d0">Optoelectronic Sensors</data>
      <data key="d1">equipment</data>
      <data key="d2">Optoelectronic Sensors are inexpensive, low-cost sensors based on microstructured polymer films doped with phosphorescent dyes that could be readily deployable for ocean monitoring.</data>
      <data key="d3">chunk-e755a3b7fb7a07c10fdd800c398a82c8</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777540350</data>
      <data key="d6" />

    <node id="Pointwise Regression">
      <data key="d0">Pointwise Regression</data>
      <data key="d1">method</data>
      <data key="d2">Pointwise regression is a method that optimizes models to produce a single "best" explanation token-by-token.</data>
      <data key="d3">chunk-a42210fb81e37b65a494b714686acf98</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777541275</data>

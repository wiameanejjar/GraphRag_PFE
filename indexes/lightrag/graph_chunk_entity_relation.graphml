    <node id="Explanation Quality Assessment">
      <data key="d0">Explanation Quality Assessment</data>
      <data key="d1">concept</data>
      <data key="d2">Explanation Quality Assessment is reformulated as a ranking problem to evaluate the relative quality of multiple candidate explanations.</data>
      <data key="d3">chunk-a42210fb81e37b65a494b714686acf98</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777541244</data>

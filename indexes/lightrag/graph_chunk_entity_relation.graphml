      <data key="d0">Microstructured Polymer Films</data>
      <data key="d1">equipment</data>
      <data key="d2">Microstructured Polymer Films are a key component of optoelectronic sensors, providing a platform for phosphorescent dyes to detect dissolved oxygen concentration.</data>
      <data key="d3">chunk-e755a3b7fb7a07c10fdd800c398a82c8</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777540352</data>
      <data key="d6" />
    </node>
    <node id="Phosphorescent Dyes">
      <data key="d0">Phosphorescent Dyes</data>
      <data key="d1">equipment</data>
      <data key="d2">Phosphorescent Dyes are used in optoelectronic sensors to detect dissolved oxygen concentration and are doped into microstructured polymer films.</data>
      <data key="d3">chunk-e755a3b7fb7a07c10fdd800c398a82c8</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777540354</data>

    <node id="Word Error Rate">
      <data key="d0">Word Error Rate</data>
      <data key="d1">concept</data>
      <data key="d2">Word Error Rate is a standard evaluation metric that focuses solely on accuracy and fails to capture transcription reliability.</data>
      <data key="d3">chunk-245522d5b100e4d1a221b34fd4f3a20d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777540260</data>

    </node>
    <node id="Pairwise Ranking Models">
      <data key="d0">Pairwise Ranking Models</data>
      <data key="d1">method</data>
      <data key="d2">Pairwise ranking models are used to avoid score compression typical of pointwise regression or binary preference objectives.</data>
      <data key="d3">chunk-a42210fb81e37b65a494b714686acf98</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777541254</data>
      <data key="d6" />
    </node>
    <node id="Regression">
      <data key="d0">Regression</data>
      <data key="d1">method</data>
      <data key="d2">Regression is used to optimize models to produce a single "best" explanation token-by-token.</data>
      <data key="d3">chunk-a42210fb81e37b65a494b714686acf98</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777541256</data>

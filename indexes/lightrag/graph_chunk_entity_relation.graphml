      <data key="d1">concept</data>
      <data key="d2">A ranking problem is used to evaluate the relative quality of multiple candidate explanations.</data>
      <data key="d3">chunk-a42210fb81e37b65a494b714686acf98</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777541244</data>

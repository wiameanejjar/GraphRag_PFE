      <data key="d0">Abstention-Aware Transcription Framework</data>
      <data key="d1">method</data>
      <data key="d2">The Abstention-Aware Transcription Framework enables ASR models to explicitly abstain from uncertain segments.</data>
      <data key="d3">chunk-245522d5b100e4d1a221b34fd4f3a20d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777540264</data>

    <node id="Model Scale">
      <data key="d0">Model Scale</data>
      <data key="d1">concept</data>
      <data key="d2">Model scale is not as important as data quality in achieving good performance.</data>
      <data key="d3">chunk-a42210fb81e37b65a494b714686acf98</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777541264</data>

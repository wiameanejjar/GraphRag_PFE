    <node id="Policy Responses">
      <data key="d0">Policy Responses</data>
      <data key="d1">concept</data>
      <data key="d2">Policy Responses are generated by the LLM policy conditioned on preference weights with rejection sampling strategy.</data>
      <data key="d3">chunk-dce3b2b12a8df42087f6abb8d46338fb</data>
      <data key="d4">unknown_source</data>

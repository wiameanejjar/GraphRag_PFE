    </node>
    <node id="Listwise Ranking Models">
      <data key="d0">Listwise Ranking Models</data>
      <data key="d1">method</data>
      <data key="d2">Listwise ranking models (ListNet, LambdaRank, RankNet) are used to preserve ordinal structure and avoid score compression.</data>
      <data key="d3">chunk-a42210fb81e37b65a494b714686acf98</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777541251</data>

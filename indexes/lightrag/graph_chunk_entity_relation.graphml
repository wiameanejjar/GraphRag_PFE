    <node id="Automatic Speech Recognition">
      <data key="d0">Automatic Speech Recognition</data>
      <data key="d1">concept</data>
      <data key="d2">Automatic Speech Recognition is a system that produces confident yet incorrect transcriptions under noisy or ambiguous conditions.</data>
      <data key="d3">chunk-245522d5b100e4d1a221b34fd4f3a20d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777540257</data>

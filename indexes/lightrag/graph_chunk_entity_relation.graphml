    </node>
    <node id="Candidate Explanations">
      <data key="d0">Candidate Explanations</data>
      <data key="d1">content</data>
      <data key="d2">Candidate explanations are evaluated based on their relative quality.</data>
      <data key="d3">chunk-a42210fb81e37b65a494b714686acf98</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1777541251</data>

    <node id="Acoustic Emission">
      <data key="d0">Acoustic Emission</data>
      <data key="d1">concept</data>
      <data key="d2">Acoustic Emission is a phenomenon where high-frequency stress waves are emitted by materials under stress.&lt;SEP&gt;Acoustic emission refers to the phenomenon of high-frequency stress waves generated by the rapid release of energy in materials.</data>
      <data key="d3">chunk-4fb1846e6da8a78f6dc58f2d85230793&lt;SEP&gt;chunk-b1a2b103d7a60591f1a23cdc33cbb4d1</data>

    <node id="Light-Based Device">
      <data key="d0">Light-Based Device</data>
      <data key="d1">equipment</data>
      <data key="d2">A light-based device uses light rays for solving the subset-sum problem. It has a graph-like representation and the light is traversing it by following the routes given by the connections between nodes.</data>
      <data key="d3">chunk-f76e2f2db6572fc7e5417d2c0bc42280</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776915547</data>
